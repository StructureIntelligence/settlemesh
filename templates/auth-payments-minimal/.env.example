# Copy to .env for LOCAL development only. Never commit real values.
# In production, SettleMesh INJECTS SETTLEMESH_APP_API_KEY for you — you do not set it.

# The app's server-side runtime key. Authenticates this app to SettleMesh.
# NEVER expose this to the browser. Placeholder only — paste your own to run locally.
SETTLEMESH_APP_API_KEY=

# Optional: override the API base (defaults to https://api.settlemesh.io).
SETTLEMESH_BASE_URL=

# Optional: local port (defaults to 8080).
PORT=
