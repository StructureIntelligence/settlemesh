# Copy to .env.local for local development. Never commit real values.
# In production, SettleMesh injects these automatically at deploy time —
# you do NOT need to set them yourself.

# Base URL for the SettleMesh API (default is fine).
SETTLEMESH_BASE_URL=https://api.settlemesh.io

# Managed database credentials (auto-injected on deploy). Placeholders only:
SETTLEMESH_PROJECT_ID=
SETTLEMESH_PROJECT_SERVER_KEY=
