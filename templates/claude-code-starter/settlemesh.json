{
  "app": {
    "name": "claude-code-starter"
  },
  "framework": "nextjs",
  "stack": {
    "auth": {
      "methods": [
        "settlemesh_oauth"
      ],
      "mode": "lazy",
      "provider": "settlemesh",
      "required": false,
      "scopes": [
        "openid",
        "profile",
        "email"
      ]
    },
    "database": {
      "engine": "sqlite"
    }
  },
  "target": "cloudflare"
}
