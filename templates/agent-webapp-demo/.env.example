# Copy to .env.local for local dev. NEVER commit real values.
# `settlemesh deploy` injects the real versions of these in production —
# you do not set them by hand for a deployed app.

# SettleMesh API base (default is fine).
SETTLEMESH_BASE_URL=https://api.settlemesh.io

# App API key — authorizes metered capability calls. Injected on deploy.
SETTLEMESH_APP_API_KEY=

# Managed database — project id + server key. Injected on deploy.
SETTLEMESH_PROJECT_ID=
SETTLEMESH_PROJECT_SERVER_KEY=

# Optional: the capability/tool ID for the "Polish with AI" button.
# Leave empty to use the local no-charge fallback. See app/api/polish/route.ts.
SETTLEMESH_POLISH_CAPABILITY=
