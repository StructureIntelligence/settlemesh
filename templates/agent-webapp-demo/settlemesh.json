{
  "app": {
    "name": "agent-webapp-demo"
  },
  "framework": "nextjs",
  "stack": {
    "auth": {
      "methods": [
        "settlemesh_oauth"
      ],
      "mode": "lazy",
      "provider": "settlemesh",
      "required": false,
      "scopes": [
        "openid",
        "profile",
        "email",
        "wallet.read",
        "wallet.spend"
      ]
    },
    "database": {
      "engine": "sqlite"
    },
    "runtime_api": {
      "enabled": true
    }
  },
  "target": "cloudflare"
}
