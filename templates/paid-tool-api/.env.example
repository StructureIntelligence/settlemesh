# Copy to .env for LOCAL development only. Never commit a real .env.
# When you `settlemesh deploy`, SettleMesh injects these for you — you do not set them in production.

# SettleMesh API base URL (defaults to https://api.settlemesh.io if unset).
SETTLEMESH_BASE_URL=

# The app's runtime API key. Injected automatically on deploy. For local testing only, paste a key here.
# This authenticates the APP; the per-call charge still lands on the logged-in user (via X-Settle-Payer).
SETTLEMESH_APP_API_KEY=

# Optional: the capability or offer id this endpoint resells. Defaults to "llm.chat".
# TOOL_CAPABILITY_ID=llm.chat
