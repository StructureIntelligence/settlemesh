{
  "app": {
    "name": "paid-tool-api"
  },
  "start": "node server.js",
  "stack": {
    "auth": {
      "methods": [
        "settlemesh_oauth"
      ],
      "mode": "lazy",
      "provider": "settlemesh",
      "required": false,
      "scopes": [
        "openid",
        "profile",
        "email",
        "wallet.read",
        "wallet.spend"
      ]
    },
    "runtime": {
      "cpu": 1,
      "memory": "512Mi"
    },
    "runtime_api": {
      "enabled": true
    },
    "billing": {
      "markup": 1.3
    }
  },
  "env": [
    "SETTLEMESH_BASE_URL",
    "SETTLEMESH_APP_API_KEY"
  ],
  "target": "cloudflare"
}
