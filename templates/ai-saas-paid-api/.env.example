# Copy to `.env` for LOCAL development only. `settlemesh deploy` injects the production values for you —
# you do NOT set these in production. NEVER commit a real key. Placeholders only.

# Injected automatically in production by `settlemesh deploy`. Authenticates this app to SettleMesh.
# Only needed locally if you want to test billable calls outside the platform.
SETTLEMESH_APP_API_KEY=

# SettleMesh API base (default is correct for production; override only for local/staging).
# SETTLEMESH_BASE_URL=https://api.settlemesh.io

# The AI capability this app charges for. Confirm the id against https://settlemesh.io/agent.md.
# SETTLEMESH_CAPABILITY_ID=llm.chat

# Display-only pre-call price estimate shown in the UI (Aev). The real charge comes from the platform.
# PRICE_ESTIMATE_AEV=2
